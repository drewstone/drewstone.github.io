---
import Base from '../../layouts/Base.astro'
import PostHistoryCard from '../../components/PostHistoryCard.astro'
import { getCollection } from 'astro:content'

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
const allTraces = await getCollection('traces')

// Group traces by post slug
const tracesByPost = new Map<string, typeof allTraces>()
for (const t of allTraces) {
  const arr = tracesByPost.get(t.data.post) ?? []
  arr.push(t)
  tracesByPost.set(t.data.post, arr)
}

// Sort posts by creation date desc (newest first)
const posts = [...allPosts].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

// Headline stats
const totalTraces = allTraces.length
const totalTurns = allTraces.reduce((s, t) => s + t.data.turns.length, 0)
const totalToolCalls = allTraces.reduce(
  (s, t) => s + t.data.turns.reduce((ss, tr) => ss + (tr.tool_calls ?? 0), 0),
  0
)
const totalRevisions = posts.reduce((s, p) => s + (p.data.revisions?.length ?? 0), 0)

const modelCounts: Record<string, number> = {}
for (const p of posts) {
  for (const a of p.data.authors ?? []) {
    const m = a.model || 'unknown'
    modelCounts[m] = (modelCounts[m] ?? 0) + 1
  }
  for (const r of p.data.revisions ?? []) {
    const m = r.model || 'unknown'
    modelCounts[m] = (modelCounts[m] ?? 0) + 1
  }
}
const sortedModels = Object.entries(modelCounts).sort((a, b) => b[1] - a[1])
const maxModel = sortedModels[0]?.[1] ?? 1

const short = (m: string | null | undefined): string => {
  if (!m || m === 'unknown') return 'unknown'
  if (m.startsWith('claude-')) {
    const p = m.replace(/^claude-/, '').split('-')
    if (p.length >= 2) return p[0][0].toUpperCase() + p[0].slice(1) + ' ' + p.slice(1).join('.')
  }
  if (m.startsWith('gpt-')) return 'GPT-' + m.replace(/^gpt-/, '')
  return m
}
---

<Base title="traces" wide>
  <section class="intro">
    <h1>Session traces</h1>
    <p>
      Every post's authorship and edit history. Click any row to expand the full revision log,
      with links to the captured session trace and the commit for each edit.
    </p>
    <p class="intro-sub">
      Captured via <code>tools/trace-capture.ts</code>. User turns trimmed to &lt;600 chars,
      assistant to &lt;280 chars with tool-call counts only. Raw JSONL stays on the authoring
      machine.
    </p>
  </section>

  <section class="stats">
    <div class="stat-card"><div class="sv">{posts.length}</div><div class="sl">Posts</div></div>
    <div class="stat-card"><div class="sv">{totalRevisions}</div><div class="sl">Revisions</div></div>
    <div class="stat-card"><div class="sv">{totalTraces}</div><div class="sl">Traces</div></div>
    <div class="stat-card"><div class="sv">{totalTurns}</div><div class="sl">Turns</div></div>
    <div class="stat-card"><div class="sv">{totalToolCalls}</div><div class="sl">Tool calls</div></div>
  </section>

  {sortedModels.length > 0 && (
    <section class="section">
      <h2>By model</h2>
      <div class="model-bars">
        {sortedModels.map(([m, n]) => (
          <div class="mb-row">
            <span class={`mb-label ${m === 'unknown' ? 'is-unknown' : ''}`}>{short(m)}</span>
            <div class="mb-track"><div class="mb-fill" style={`width: ${(n / maxModel) * 100}%`}></div></div>
            <span class="mb-count">{n}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <div class="section-head">
      <h2>History by post</h2>
      <div class="sort-controls" role="group" aria-label="sort order">
        <button data-sort="created" class="sort-btn is-active">Created ↓</button>
        <button data-sort="updated" class="sort-btn">Updated ↓</button>
      </div>
    </div>

    <div class="phc-header" aria-hidden="true">
      <span></span>
      <span>Post</span>
      <span>Created</span>
      <span>Written by</span>
      <span>Updated</span>
      <span>Last model</span>
      <span>Revs</span>
    </div>

    <div class="phc-list">
      {posts.map((post) => (
        <PostHistoryCard post={post} traces={tracesByPost.get(post.id) ?? []} />
      ))}
    </div>
  </section>

  <script>
    (function() {
      const list = document.querySelector('.phc-list')
      const btns = document.querySelectorAll<HTMLButtonElement>('.sort-btn')
      if (!list || !btns.length) return
      for (const b of btns) {
        b.addEventListener('click', () => {
          const key = b.dataset.sort!
          const cards = Array.from(list.querySelectorAll<HTMLElement>('.phc'))
          cards.sort((a, b) => {
            const av = a.dataset[key === 'created' ? 'created' : 'updated'] ?? ''
            const bv = b.dataset[key === 'created' ? 'created' : 'updated'] ?? ''
            return bv.localeCompare(av)
          })
          for (const c of cards) list.appendChild(c)
          for (const x of btns) x.classList.toggle('is-active', x === b)
        })
      }
    })()
  </script>
</Base>

<style>
  .intro { margin: var(--space-xl) 0 var(--space-2xl); max-width: 780px; }
  .intro h1 { font-size: 2.4rem; letter-spacing: -0.02em; margin: 0 0 var(--space-md); }
  .intro p { font-size: 1.08rem; line-height: 1.6; margin: 0 0 var(--space-md); }
  .intro-sub { color: var(--fg-muted); font-size: 0.95rem !important; }
  .intro code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 0.08em 0.3em;
    background: var(--bg-alt);
    border-radius: 3px;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.6rem;
    margin: 0 0 var(--space-2xl);
  }
  .stat-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.85rem 1rem;
    background: var(--bg);
  }
  .sv {
    font-family: var(--font-body);
    font-size: 1.9rem;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--c-action);
  }
  .sl {
    font-family: var(--font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
    margin-top: 0.35rem;
  }

  .section { margin: 0 0 var(--space-2xl); }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    margin: 0 0 var(--space-md);
    padding-bottom: 0.4rem;
    border-bottom: 1px dotted var(--border);
  }
  .section h2 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0;
  }

  .sort-controls {
    display: inline-flex;
    gap: 0.3rem;
  }
  .sort-btn {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.65rem;
    background: var(--bg);
    color: var(--fg-muted);
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .sort-btn:hover { background: var(--bg-alt); color: var(--fg); }
  .sort-btn.is-active {
    background: var(--c-action-bg);
    color: var(--c-action);
    border-color: var(--c-action-border);
  }

  .model-bars { display: flex; flex-direction: column; gap: 0.5rem; }
  .mb-row {
    display: grid;
    grid-template-columns: 180px 1fr 3rem;
    align-items: center;
    gap: 0.8rem;
  }
  .mb-label { font-family: var(--font-mono); font-size: 12px; font-weight: 600; color: var(--fg); }
  .mb-label.is-unknown { color: var(--fg-faint); font-style: italic; font-weight: 500; }
  .mb-track { height: 10px; background: var(--bg-alt); border-radius: 5px; overflow: hidden; }
  .mb-fill { height: 100%; background: var(--c-action); border-radius: 5px; }
  .mb-count {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--fg-muted);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  /* PostHistoryCard header row — aligns with grid in the summary */
  .phc-header {
    display: grid;
    grid-template-columns:
      1.4rem
      minmax(0, 1.6fr)
      7rem
      7rem
      7rem
      7rem
      4.5rem;
    gap: 0.9rem;
    padding: 0.5rem 0.95rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-bottom: 0;
    border-radius: 10px 10px 0 0;
  }
  .phc-list {
    border: 1px solid var(--border);
    border-top: 0;
    border-radius: 0 0 10px 10px;
    background: var(--bg);
    overflow: hidden;
  }

  @media (max-width: 800px) {
    .phc-header { display: none; }
    .phc-list { border-radius: 10px; border-top: 1px solid var(--border); }
  }
</style>
