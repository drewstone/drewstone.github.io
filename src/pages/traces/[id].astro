---
import Base from '../../layouts/Base.astro'
import { getCollection } from 'astro:content'
import { execSync } from 'node:child_process'
import { readFile } from 'node:fs/promises'
import { codeToHtml } from 'shiki'

export async function getStaticPaths() {
  const traces = await getCollection('traces')
  return traces.map((t) => ({
    params: { id: t.data.trace_id },
    props: { trace: t },
  }))
}

const { trace } = Astro.props
const d = trace.data

// Resolve a diff per file the trace touched. Each file gets its own
// syntax-highlighted block. If the commit is missing/HEAD or the file no
// longer exists in the diff, fall back to "current file" preview for that
// file. Everything happens at build time; failures degrade silently.
type FileDiff = {
  path: string
  html: string
  kind: 'commit' | 'current' | 'none'
  additions: number
  deletions: number
}

const targetFiles: string[] = (d.files_touched ?? []).filter((f: string) =>
  /\.(mdx|md|ts|tsx|js|mjs|astro|css|json)$/.test(f),
)
const primaryFile = targetFiles[0] ?? `src/content/posts/${d.post}.mdx`

async function highlight(src: string, lang: string) {
  try {
    let h = await codeToHtml(src, {
      lang,
      themes: { light: 'github-light', dark: 'github-dark' },
    })
    h = h.replace(/<\/span>\n(<span class="line">)/g, '</span>$1')
    return h
  } catch {
    return `<pre><code>${src.replace(/[<>&]/g, (c) => ({'<':'&lt;','>':'&gt;','&':'&amp;'} as any)[c])}</code></pre>`
  }
}

function langFor(path: string) {
  if (path.endsWith('.mdx')) return 'mdx'
  if (path.endsWith('.md')) return 'markdown'
  if (path.endsWith('.astro')) return 'astro'
  if (path.endsWith('.ts') || path.endsWith('.tsx')) return 'ts'
  if (path.endsWith('.js') || path.endsWith('.mjs')) return 'js'
  if (path.endsWith('.css')) return 'css'
  if (path.endsWith('.json')) return 'json'
  return 'text'
}

const diffstatByFile = new Map<string, { additions: number; deletions: number }>()
for (const s of (d as any).diffstat ?? []) diffstatByFile.set(s.path, { additions: s.additions, deletions: s.deletions })

const fileDiffs: FileDiff[] = []
for (const f of targetFiles) {
  let kind: FileDiff['kind'] = 'none'
  let raw = ''
  if (d.commit && d.commit !== 'HEAD') {
    try {
      const cmd = `git show --no-renames --format='' ${d.commit} -- '${f.replace(/'/g, "'\\''")}'`
      const out = execSync(cmd, { cwd: process.cwd(), stdio: ['ignore', 'pipe', 'ignore'] }).toString()
      if (out.trim()) { raw = out; kind = 'commit' }
    } catch {}
  }
  if (!raw) {
    try {
      const fileRaw = await readFile(f, 'utf8')
      raw = fileRaw.split('\n').slice(0, 80).join('\n')
      kind = 'current'
    } catch { raw = '' }
  }
  if (!raw) continue
  const html = await highlight(raw, kind === 'commit' ? 'diff' : langFor(f))
  const stat = diffstatByFile.get(f) ?? { additions: 0, deletions: 0 }
  fileDiffs.push({ path: f, html, kind, additions: stat.additions, deletions: stat.deletions })
}

const totalAdditions = fileDiffs.reduce((s, x) => s + x.additions, 0)
const totalDeletions = fileDiffs.reduce((s, x) => s + x.deletions, 0)
const anyCommitDiff = fileDiffs.some((x) => x.kind === 'commit')

const posts = await getCollection('posts')
const post = posts.find((p) => p.id === d.post)
const postCreated = post?.data.date

const short = (model: string | null | undefined): string => {
  if (!model) return 'unknown'
  if (model.startsWith('claude-')) {
    const parts = model.replace(/^claude-/, '').split('-')
    if (parts.length >= 2) return parts[0][0].toUpperCase() + parts[0].slice(1) + ' ' + parts.slice(1).join('.')
  }
  if (model.startsWith('gpt-')) return 'GPT-' + model.replace(/^gpt-/, '')
  return model
}

const fmtFull = (s: string) =>
  new Date(s).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' })

const fmtShort = (d: Date | string) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })

const durationMs = d.ended_at ? new Date(d.ended_at).valueOf() - new Date(d.started_at).valueOf() : 0
const durationMin = Math.round(durationMs / 60_000)

// Pre-render any extracted code/inputs so the page renders deterministically.
type RenderedTurn = {
  role: string
  ts?: string
  body?: string
  bodyTruncated?: boolean
  hadThinking?: boolean
  tools?: { name: string; input_html?: string; input_lang?: string; file_path?: string; result_preview?: string }[]
  filesTouched?: string[]
}

function langForTool(name: string, file_path?: string) {
  if (name === 'Bash') return 'bash'
  if (file_path) return langFor(file_path)
  return 'json'
}

const renderedTurns: RenderedTurn[] = []
for (const t of d.turns as any[]) {
  const body = t.text ?? t.text_summary ?? ''
  const truncated = !!(t.text_summary && !t.text)
  const tools: RenderedTurn['tools'] = []
  if (Array.isArray(t.tool_call_details) && t.tool_call_details.length) {
    for (const det of t.tool_call_details) {
      const lang = langForTool(det.name, det.file_path)
      const input_html = det.input_preview ? await highlight(det.input_preview, lang) : undefined
      tools.push({
        name: det.name,
        input_html,
        input_lang: lang,
        file_path: det.file_path,
        result_preview: det.result_preview,
      })
    }
  } else if (Array.isArray(t.tool_names) && t.tool_names.length) {
    // Old shape — name only, no args. Render a stub.
    for (const name of t.tool_names) tools.push({ name })
  }
  renderedTurns.push({
    role: t.role,
    ts: t.ts,
    body,
    bodyTruncated: truncated,
    hadThinking: !!t.had_thinking,
    tools,
    filesTouched: t.files_touched ?? [],
  })
}

const repo = import.meta.env.PUBLIC_REPO_SLUG as string | undefined
---

<Base title={`Trace · ${d.trace_id}`} description={`Captured agent session for "${post?.data.title ?? d.post}". Model: ${d.model}, ${d.turns?.length ?? 0} turns.`} wide>
  <nav class="trace-nav">
    <a href="/traces">← all traces</a>
  </nav>

  <header class="trace-header">
    <div class="trace-meta">
      <span class="trace-model">{short(d.model)}</span>
      <span class="trace-harness">{d.harness}</span>
    </div>
    <h1>
      {post ? <a href={`/posts/${d.post}`}>{post.data.title}</a> : d.post}
    </h1>
    <p class="trace-summary">{d.summary}</p>
    <dl class="trace-dates">
      {postCreated && (
        <>
          <dt>Created</dt>
          <dd><time datetime={postCreated.toISOString()}>{fmtShort(postCreated)}</time></dd>
        </>
      )}
      <dt>Updated</dt>
      <dd><time datetime={new Date(d.started_at).toISOString()}>{fmtFull(d.started_at)}</time></dd>
    </dl>
  </header>

  <section class="trace-stats">
    <div class="ts-card"><div class="ts-v">{d.turns.length}</div><div class="ts-l">Turns</div></div>
    <div class="ts-card"><div class="ts-v">{d.turns.reduce((s: number, t: any) => s + (t.tool_calls ?? 0), 0)}</div><div class="ts-l">Tool calls</div></div>
    <div class="ts-card"><div class="ts-v">{d.files_touched.length}</div><div class="ts-l">Files touched</div></div>
    {durationMin > 0 && (
      <div class="ts-card"><div class="ts-v">{durationMin}m</div><div class="ts-l">Duration</div></div>
    )}
  </section>

  {d.files_touched.length > 0 && (
    <section class="trace-files">
      <h2 class="files-label">Files</h2>
      <ul>
        {d.files_touched.map((f: string) => (
          <li><code>{f}</code></li>
        ))}
      </ul>
    </section>
  )}

  {d.commit && (
    <section class="trace-commit">
      <h2 class="files-label">Commit</h2>
      <div class="commit-card">
        <div class="commit-row">
          <code class="commit-sha">{d.commit.slice(0, 7)}</code>
          {(d as any).commit_subject && <span class="commit-subject">{(d as any).commit_subject}</span>}
          {repo && (
            <a class="commit-ext" href={`https://github.com/${repo}/commit/${d.commit}`} target="_blank" rel="noopener">view on GitHub →</a>
          )}
        </div>
        {(d as any).commit_message && (d as any).commit_message !== (d as any).commit_subject && (
          <pre class="commit-body">{(d as any).commit_message}</pre>
        )}
        {(totalAdditions + totalDeletions) > 0 && (
          <div class="commit-stat">
            <span class="stat-add">+{totalAdditions}</span>
            <span class="stat-del">−{totalDeletions}</span>
            <span class="stat-files">across {fileDiffs.length} file{fileDiffs.length === 1 ? '' : 's'}</span>
          </div>
        )}
      </div>
    </section>
  )}

  {(d as any).intent && (
    <section class="trace-intent">
      <h2 class="files-label">Intent</h2>
      <p>{(d as any).intent}</p>
    </section>
  )}

  {Array.isArray((d as any).scores) && (d as any).scores.length > 0 && (
    <section class="trace-scores">
      <h2 class="files-label">Scorecard</h2>
      <ul class="scores">
        {(d as any).scores.map((sc: any) => (
          <li class="score">
            <div class="score-head">
              <span class="score-judge">{sc.judge}</span>
              {typeof sc.overall === 'number' && (
                <span class="score-overall">{Math.round(sc.overall)}</span>
              )}
              {sc.scored_at && (
                <time class="score-when">{fmtShort(sc.scored_at)}</time>
              )}
            </div>
            {sc.dimensions && (
              <ul class="score-dims">
                {Object.entries(sc.dimensions).map(([k, v]) => (
                  <li><span>{k}</span><strong>{Math.round(Number(v))}</strong></li>
                ))}
              </ul>
            )}
            {sc.notes && <p class="score-notes">{sc.notes}</p>}
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="trace-section">
    <h2 class="files-label">Conversation</h2>
    <p class="section-tip">{renderedTurns.length} turn{renderedTurns.length === 1 ? '' : 's'}. Full text where captured; older traces show only the first ~280 chars.</p>
    <ol class="turns">
      {renderedTurns.map((t, i) => (
        <li class={`turn turn-${t.role}`}>
          <div class="turn-rail" aria-hidden="true"></div>
          <div class="turn-body">
            <div class="turn-head">
              <span class="turn-role">{t.role}</span>
              <span class="turn-i">#{i + 1}</span>
              {t.ts && <time class="turn-ts">{new Date(t.ts).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}</time>}
              {t.hadThinking && <span class="turn-think">thinking</span>}
              {t.tools && t.tools.length > 0 && (
                <span class="turn-tools-count">{t.tools.length} tool{t.tools.length === 1 ? '' : 's'}</span>
              )}
            </div>
            {t.body && (
              <div class={`turn-text${t.bodyTruncated ? ' is-trunc' : ''}`}>
                {t.body}
                {t.bodyTruncated && <div class="turn-trunc-note">(truncated to 280 chars — older capture)</div>}
              </div>
            )}
            {t.tools && t.tools.length > 0 && (
              <ul class="tool-list">
                {t.tools.map((tc) => (
                  <li class="tool-row">
                    <div class="tool-head">
                      <span class="tool-name">{tc.name}</span>
                      {tc.file_path && <code class="tool-file">{tc.file_path}</code>}
                    </div>
                    {tc.input_html ? (
                      <details class="tool-input">
                        <summary>input</summary>
                        <div class="tool-input-code" set:html={tc.input_html} />
                      </details>
                    ) : (
                      <div class="tool-stub">(input not captured in this trace)</div>
                    )}
                    {tc.result_preview && (
                      <details class="tool-result">
                        <summary>result</summary>
                        <pre>{tc.result_preview}</pre>
                      </details>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </li>
      ))}
    </ol>
  </section>

  {fileDiffs.length > 0 && (
    <section class="trace-section">
      <h2 class="files-label">Diff</h2>
      <p class="section-tip">
        {anyCommitDiff
          ? <>Per-file changes from <code>{d.commit?.slice(0, 7)}</code>.</>
          : <>No commit diff available — showing current file content (first 80 lines).</>}
      </p>
      {fileDiffs.map((fd) => (
        <div class="diff-body">
          <div class="diff-meta">
            <span class="diff-file"><code>{fd.path}</code></span>
            {fd.kind === 'commit' && (fd.additions + fd.deletions) > 0 && (
              <span class="diff-numstat">
                <span class="stat-add">+{fd.additions}</span>
                <span class="stat-del">−{fd.deletions}</span>
              </span>
            )}
            {fd.kind === 'current' && (
              <span class="diff-kind-label">current file (first 80 lines)</span>
            )}
          </div>
          <div class="diff-code" set:html={fd.html} />
        </div>
      ))}
    </section>
  )}

  <footer class="trace-footer">
    {post && <a href={`/posts/${d.post}`}>← back to {post.data.title}</a>}
  </footer>
</Base>

<style>
  .trace-nav {
    margin: var(--space-xl) 0 var(--space-md);
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .trace-nav a {
    color: var(--fg-muted);
    text-decoration: none;
  }
  .trace-nav a:hover { color: var(--fg); }

  .trace-header { margin: 0 0 var(--space-xl); }
  .trace-meta {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    margin-bottom: var(--space-md);
  }
  .trace-role {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    background: var(--c-action-bg);
    color: var(--c-action);
    border: 1px solid var(--c-action-border);
  }
  .trace-model {
    font-size: 12px;
    font-weight: 600;
    color: var(--fg);
  }
  .trace-harness {
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-faint);
  }
  .trace-meta time {
    margin-left: auto;
    font-size: 11px;
    color: var(--fg-faint);
  }

  .trace-header h1 {
    font-size: 2.2rem;
    letter-spacing: -0.015em;
    margin: 0 0 var(--space-sm);
    line-height: 1.15;
  }
  .trace-header h1 a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 2px solid var(--c-action-border);
  }
  .trace-header h1 a:hover { border-bottom-color: var(--c-action); }

  .trace-summary {
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--fg-muted);
    font-style: italic;
    margin: 0 0 var(--space-md);
    max-width: 720px;
  }

  .trace-dates {
    display: grid;
    grid-template-columns: auto auto;
    gap: 0.2rem 0.8rem;
    margin: 0;
    padding: 0.55rem 0.8rem;
    background: var(--bg-alt);
    border-radius: 6px;
    display: inline-grid;
    max-width: max-content;
  }
  .trace-dates dt {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fg-faint);
    margin: 0;
  }
  .trace-dates dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--fg);
    font-variant-numeric: tabular-nums;
  }

  .trace-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.6rem;
    margin: 0 0 var(--space-xl);
  }
  .ts-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 0.95rem;
    background: var(--bg);
  }
  .ts-v {
    font-family: var(--font-body);
    font-size: 1.7rem;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--c-action);
  }
  .ts-l {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
    margin-top: 0.25rem;
  }

  .files-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fg-faint);
    margin: 0 0 var(--space-md);
  }

  .trace-files { margin: 0 0 var(--space-xl); }
  .trace-files ul { list-style: none; padding: 0; margin: 0; }
  .trace-files li {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .trace-files li:last-child { border-bottom: 0; }
  .trace-files code {
    font-size: 0.85rem;
    background: transparent;
    padding: 0;
  }

  .trace-commit, .trace-intent, .trace-scores { margin: 0 0 var(--space-xl); }
  .commit-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.7rem 0.95rem;
    background: var(--bg);
  }
  .commit-row {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .commit-sha {
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 700;
    color: var(--c-action);
    background: var(--c-action-bg);
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    border: 1px solid var(--c-action-border);
  }
  .commit-subject {
    font-family: var(--font-body);
    font-size: 1.02rem;
    color: var(--fg);
    line-height: 1.4;
  }
  .commit-ext {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
    text-decoration: none;
  }
  .commit-ext:hover { color: var(--c-action); }
  .commit-body {
    margin: 0.55rem 0 0;
    padding: 0.55rem 0.7rem;
    background: var(--bg-alt);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-muted);
    white-space: pre-wrap;
    line-height: 1.55;
    overflow-x: auto;
  }
  .commit-stat {
    display: flex;
    gap: 0.7rem;
    align-items: baseline;
    margin-top: 0.55rem;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--fg-faint);
  }
  .stat-add { color: var(--c-ok); font-weight: 700; }
  .stat-del { color: var(--c-fail); font-weight: 700; }
  .stat-files { color: var(--fg-muted); }

  .trace-intent p {
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--fg);
    margin: 0;
    padding: 0.75rem 0.95rem;
    border-left: 3px solid var(--c-action);
    background: var(--bg-alt);
    border-radius: 0 6px 6px 0;
  }

  .scores { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.6rem; }
  .score {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.7rem 0.95rem;
    background: var(--bg);
  }
  .score-head { display: flex; align-items: baseline; gap: 0.7rem; }
  .score-judge {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-action);
  }
  .score-overall {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--fg);
    line-height: 1;
  }
  .score-when {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
  }
  .score-dims { list-style: none; padding: 0; margin: 0.55rem 0 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.4rem 0.8rem; }
  .score-dims li { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 11.5px; color: var(--fg-muted); border-bottom: 1px dotted var(--border); padding: 0.2rem 0; }
  .score-dims li strong { color: var(--fg); font-weight: 700; }
  .score-notes { margin: 0.55rem 0 0; font-size: 0.92rem; color: var(--fg-muted); line-height: 1.5; }

  .section-tip { font-size: 0.92rem; color: var(--fg-muted); margin: 0 0 var(--space-md); }
  .section-tip code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-alt);
    padding: 0.05em 0.35em;
    border-radius: 3px;
  }
  .trace-section { margin: 0 0 var(--space-2xl); }

  .turns { list-style: none; padding: 0; margin: 0 0 var(--space-xl); }
  .turn {
    display: grid;
    grid-template-columns: 4px 1fr;
    gap: 0.9rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }
  .turn:last-child { border-bottom: 0; }
  .turn-rail { border-radius: 2px; align-self: stretch; background: var(--border); }
  .turn-user .turn-rail { background: var(--c-human, var(--fg)); }
  .turn-assistant .turn-rail { background: var(--c-action); }
  .turn-tool .turn-rail { background: var(--c-info, var(--fg-muted)); }
  .turn-head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
    margin-bottom: 0.4rem;
  }
  .turn-role {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg);
  }
  .turn-user .turn-role { color: var(--c-human, var(--fg)); }
  .turn-assistant .turn-role { color: var(--c-action); }
