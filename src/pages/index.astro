    padding-bottom: 0.4rem;
    border-bottom: 1px dotted var(--border);
  }
  .home-section-head h2 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0;
