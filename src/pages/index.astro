    margin: 0;
    max-width: none;
  }
  .intro p {
    font-size: 1.08rem;
    line-height: 1.65;
    margin: 0 0 var(--space-md);
    color: var(--fg);
  }
  .intro-lead strong { font-weight: 700; }
  .intro-meta {
    color: var(--fg-muted);
    font-size: 1rem !important;
  }
  .intro-meta strong {
    color: var(--fg);
    font-variant-numeric: tabular-nums;
    font-weight: 700;
  }
  .intro-features {
    color: var(--fg-muted);
    font-size: 0.95rem !important;
  }
  .intro-caps {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-action);
    margin-right: 0.2em;
  }
  .intro a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--c-action-border);
    text-underline-offset: 3px;
  }
  .intro a:hover {
    text-decoration-color: var(--c-action);
  }

  /* ===== Inline experiment lede — second paragraph in the intro column ===== */
  .experiment-lede {
    font-family: var(--font-body);
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--fg);
    margin: var(--space-md) 0 0;
  }
  .experiment-lede-mark {
    font-weight: 700;
    font-size: 1.35em;
    letter-spacing: 0.02em;
    color: var(--c-action);
    text-transform: uppercase;
    font-variant: small-caps;
    margin-right: 0.18em;
