    text-underline-offset: 3px;
  }
  .experiment-lede a:hover { text-decoration-color: var(--c-action); }
  .experiment-lede strong { font-weight: 700; }
  .experiment-lede-human {
    color: #00b347;
    font-weight: 700;
    font-style: italic;
  }
  @media (prefers-color-scheme: dark) {
    .experiment-lede-human {
      color: #39ff88;
      text-shadow: 0 0 12px rgba(57, 255, 136, 0.45);
    }
  }
  .experiment-stats .stats-human span { color: var(--c-human); opacity: 0.8; }

  /* ===== Newest side column ===== */
  .hero-side {
    min-width: 0;
    padding-top: 0.25rem;
  }
  .hero-side-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin: 0 0 0.7rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px dotted var(--border);
  }
  .hero-side-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fg);
  }
  .hero-side-more {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 10.5px;
