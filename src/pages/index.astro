    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--fg-faint);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Originals section — distinct human color */
  .originals-section {
    border: 1px solid var(--c-human-border);
    border-radius: 10px;
    padding: 0.85rem 1.1rem 1rem;
    background: var(--c-human-bg);
  }
  .originals-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin: 0 0 var(--space-sm);
    padding-bottom: 0.4rem;
    border-bottom: 1px dotted var(--c-human-border);
  }
  .originals-head h2 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0;
    color: var(--c-human);
  }
