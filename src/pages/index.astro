  // noop: this homepage is entirely SSR; section rendering is below.
</script>

<style>
  /* ===== Intro block ===== */
  .intro {
    margin: var(--space-xl) 0 var(--space-3xl);
    max-width: 720px;
  }
  .intro p {
    font-size: 1.08rem;
    line-height: 1.65;
    margin: 0 0 var(--space-md);
    color: var(--fg);
  }
  .intro-lead strong { font-weight: 700; }
  .intro-meta {
    color: var(--fg-muted);
    font-size: 1rem !important;
  }
  .intro-meta strong {
    color: var(--fg);
    font-variant-numeric: tabular-nums;
    font-weight: 700;
  }
  .intro-features {
    color: var(--fg-muted);
    font-size: 0.95rem !important;
  }
  .intro-caps {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-action);
    margin-right: 0.2em;
  }
  .intro a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--c-action-border);
    text-underline-offset: 3px;
  }
  .intro a:hover {
    text-decoration-color: var(--c-action);
  }

  /* ===== Section grid ===== */
  .home-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  .home-section { margin: 0; }

  .home-section-head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0 0 var(--space-md);
    padding-bottom: 0.4rem;
    border-bottom: 1px dotted var(--border);
  }
  .home-section-head h2 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0;
    color: var(--fg);
  }
  .home-section-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
    font-variant-numeric: tabular-nums;
    margin-left: auto;
  }

  .section-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 2.5rem;
    row-gap: 0.35rem;
  }

  @media (max-width: 720px) {
    .section-list { grid-template-columns: 1fr; }
  }

  .section-list li {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    padding: 0.15rem 0;
    min-width: 0;
  }

  .bullet {
    color: var(--c-action);
    font-size: 10px;
    flex-shrink: 0;
    transform: translateY(-1px);
  }

  .item-link {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.45;
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--fg-faint);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }
  .item-link:hover {
    text-decoration-color: var(--fg);
  }

  .item-date {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--fg-faint);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .see-more {
    margin: var(--space-3xl) 0 var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px dotted var(--border);
    text-align: center;
  }
  .see-more a {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    text-decoration: none;
  }
  .see-more a:hover { color: var(--fg); }
</style>

