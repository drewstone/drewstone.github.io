    padding-bottom: var(--space-xl);
    border-bottom: 1px dotted var(--border);
  }

  @media (max-width: 880px) {
    .hero { grid-template-columns: 1fr; gap: 1.8rem; }
  }

  /* ===== Intro block ===== */
  .intro {
    margin: 0;
    max-width: none;
  }
  .intro p {
    font-size: 1.08rem;
    line-height: 1.65;
    margin: 0 0 var(--space-md);
    color: var(--fg);
  }
  .intro-lead strong { font-weight: 700; }
  .intro-meta {
    color: var(--fg-muted);
    font-size: 1rem !important;
  }
  .intro-meta strong {
    color: var(--fg);
    font-variant-numeric: tabular-nums;
    font-weight: 700;
  }
  .intro-features {
    color: var(--fg-muted);
    font-size: 0.95rem !important;
  }
  .intro-caps {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-action);
    margin-right: 0.2em;
  }
  .intro a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--c-action-border);
    text-underline-offset: 3px;
  }
  .intro a:hover {
    text-decoration-color: var(--c-action);
  }

  /* ===== Newest side column ===== */
  .hero-side {
    min-width: 0;
    padding-top: 0.25rem;
  }
  .hero-side-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    margin: 0 0 0.7rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px dotted var(--border);
  }
  .hero-side-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fg);
  }
  .hero-side-more {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--fg-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero-side-more:hover { color: var(--fg); }

  .hero-side-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .hero-side-list li {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.1rem 0;
    min-width: 0;
  }
  .hs-bullet {
    color: var(--c-action);
    flex-shrink: 0;
    transform: translateY(1px);
  }
  .hs-bullet svg { display: block; }
  .hero-side-list a {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.4;
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--fg-faint);
    text-underline-offset: 3px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }
  .hero-side-list a:hover { text-decoration-color: var(--fg); }

  /* ===== Section grid ===== */
  .home-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  .home-section { margin: 0; }

  .home-section-head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0 0 var(--space-md);
    padding-bottom: 0.4rem;
    border-bottom: 1px dotted var(--border);
  }
  .home-section-head h2 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0;
    color: var(--fg);
  }
  .home-section-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-faint);
    font-variant-numeric: tabular-nums;
