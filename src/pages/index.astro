---
import Base from '../layouts/Base.astro'
import HomeSection from '../components/HomeSection.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

type Post = (typeof posts)[number]

// Editorial categories — kept intentionally small so sections don't repeat the
// same posts. Each post lands in AT MOST ONE category, in priority order. A
// post that matches none just stays in Newest / Featured.
const CATEGORIES: { key: string; title: string; matchTags: string[] }[] = [
  { key: 'math',    title: 'Math & Theory',    matchTags: ['math', 'algorithms', 'optimization'] },
  { key: 'design',  title: 'Design & UI',      matchTags: ['design', 'ui'] },
]

function categoryFor(post: Post): string | null {
  const tags = (post.data.tags ?? []).map((t) => t.toLowerCase())
  for (const cat of CATEGORIES) {
    if (tags.some((t) => cat.matchTags.includes(t))) return cat.key
  }
  return null
}

const newest = posts.slice(0, 12)
const featured = posts.filter((p) => p.data.featured)
const byCategory = new Map<string, Post[]>()
for (const p of posts) {
  const key = categoryFor(p)
  if (!key) continue
  const arr = byCategory.get(key) ?? []
  arr.push(p)
  byCategory.set(key, arr)
}

function fmtMonth(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
}

const totalRevisions = posts.reduce((s, p) => s + (p.data.revisions?.length ?? 0), 0)
const distinctModels = new Set<string>()
for (const p of posts) {
  for (const a of p.data.authors ?? []) if (a.model !== 'unknown') distinctModels.add(a.model)
  for (const r of p.data.revisions ?? []) if (r.model !== 'unknown') distinctModels.add(r.model)
}
---

<Base title="drew" wide>
  <section class="hero">
    <div class="intro">
      <p class="intro-lead">
        Hi, I'm <strong>Drew</strong>. I work on AI and autoresearch infrastructure at
        <a href="https://tangle.tools">Tangle</a>: <strong>sandboxes for agents</strong>,
        <strong>eval harnesses</strong>, and <strong>loops that automatically build
        autoresearch pipelines</strong> and run the optimization against them. Also crypto
        &mdash; specifically <strong>stablecoin payments</strong> and <strong>privacy</strong>.
        Most of what's written here is a by-product of that work.
      </p>
      <p class="intro-meta">
        <span class="intro-caps">The experiment</span>: every post was drafted, edited, or
        revisited by AI agents under my direction. Each carries a
        <a href="/experiment">revision log</a> with the model that wrote it, and every edit links
        to its <a href="/traces">captured session trace</a>. As of today:
        <strong>{posts.length} posts</strong>,
        <strong>{totalRevisions} tracked revisions</strong>,
        <strong>{distinctModels.size}</strong> distinct models with confirmed attribution.
      </p>
    </div>
    <aside class="hero-side">
      <div class="hero-side-head">
        <span class="hero-side-label">Newest</span>
        <a class="hero-side-more" href="/posts">archive &rarr;</a>
      </div>
      <ol class="hero-side-list">
        {newest.slice(0, 7).map((post) => (
          <li>
            <span class="hs-bullet" aria-hidden="true">
              <svg viewBox="0 0 10 10" width="9" height="9"><path d="M5 0l2.5 5L5 10 2.5 5z" fill="currentColor"/></svg>
            </span>
            <a href={`/posts/${post.id}`}>{post.data.title}</a>
          </li>
        ))}
      </ol>
    </aside>
  </section>

  <div class="home-grid">
    {featured.length > 0 && <HomeSection title="Featured" posts={featured} />}
    {CATEGORIES.filter((c) => byCategory.has(c.key)).map((c) => (
      <HomeSection title={c.title} posts={byCategory.get(c.key)!.slice(0, 12)} />
    ))}
  </div>

  <section class="see-more">
    <a href="/posts">full archive &rarr;</a>
  </section>
</Base>

{/* Local section component — inline Astro fragment via slot alternative is noisy,
    so we use a TypeScript-as-JSX inline pattern via a helper. */}

<script is:inline>
  // noop: this homepage is entirely SSR; section rendering is below.
</script>

<style>
  /* ===== Hero: side-by-side intro + newest ===== */
