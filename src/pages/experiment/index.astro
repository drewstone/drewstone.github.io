---
import Base from '../../layouts/Base.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const aiPosts = posts.filter((p) => !p.data.original)
const originals = posts.filter((p) => p.data.original)

type Rev = {
  date: Date
  model: string
  note: string
  commit?: string
  reconstructed?: boolean
  trace_id?: string
  author?: string
  postId: string
  postTitle: string
}

const isHuman = (m: string) => m === 'human' || m === 'drew-stone'

const allRevisions: Rev[] = []
const modelCounts: Record<string, number> = {}
const modelPosts: Record<string, Set<string>> = {}
const modelLatest: Record<string, Date> = {}

for (const post of aiPosts) {
  for (const r of post.data.revisions ?? []) {
    const rev = { ...r, postId: post.id, postTitle: post.data.title }
    allRevisions.push(rev)
    modelCounts[r.model] = (modelCounts[r.model] ?? 0) + 1
    if (!modelPosts[r.model]) modelPosts[r.model] = new Set()
    modelPosts[r.model].add(post.data.title)
    if (!modelLatest[r.model] || r.date > modelLatest[r.model]) modelLatest[r.model] = r.date
  }
}

allRevisions.sort((a, b) => b.date.valueOf() - a.date.valueOf())

const totalRevisions = allRevisions.length
const reconstructedCount = allRevisions.filter((r) => r.reconstructed).length
const distinctModels = Object.keys(modelCounts).filter((m) => m !== 'unknown' && !isHuman(m)).length
const humanRevisionCount = allRevisions.filter((r) => isHuman(r.model)).length
const sortedModels = Object.entries(modelCounts).sort((a, b) => b[1] - a[1])
const maxModel = sortedModels[0]?.[1] ?? 1

// Per-post: revision count + ordered revisions for the timeline strip
const perPost = aiPosts
  .map((p) => ({
    id: p.id,
    title: p.data.title,
    date: p.data.date,
    revs: (p.data.revisions ?? []).slice().sort((a, b) => a.date.valueOf() - b.date.valueOf()),
  }))
  .filter((x) => x.revs.length > 0)
  .sort((a, b) => b.revs.length - a.revs.length)

// Activity: most recent 20
const recent = allRevisions.slice(0, 20)

// Date range for timeline normalization
const allDates = allRevisions.map((r) => r.date.valueOf())
const minTs = Math.min(...allDates, ...aiPosts.map((p) => p.data.date.valueOf()))
const maxTs = Math.max(...allDates, Date.now())
const tsRange = Math.max(1, maxTs - minTs)
const tsPos = (d: Date) => ((d.valueOf() - minTs) / tsRange) * 100

// Color by model — deterministic mapping. Human always renders in green;
// other authors round-robin a small palette of semantic vars.
const aiPalette = ['--c-action', '--c-info', '--c-run', '--c-fail']
const colorForModel: Record<string, string> = {}
let aiIdx = 0
sortedModels.forEach(([m]) => {
  if (m === 'unknown') colorForModel[m] = '--fg-faint'
  else if (isHuman(m)) colorForModel[m] = '--c-human'
  else { colorForModel[m] = aiPalette[aiIdx % aiPalette.length]; aiIdx++ }
})

// Pick a representative human revision to read its `author` for display.
const humanAuthor = (() => {
  for (const r of allRevisions) if (isHuman(r.model) && r.author) return r.author
  return 'Drew Stone'
})()

const short = (model: string): string => {
  if (!model || model === 'unknown') return 'unknown'
  if (isHuman(model)) return humanAuthor
  if (model.startsWith('claude-')) {
    const parts = model.replace(/^claude-/, '').split('-')
    if (parts.length >= 2) return parts[0][0].toUpperCase() + parts[0].slice(1) + ' ' + parts.slice(1).join('.')
  }
  if (model.startsWith('gpt-')) return 'GPT-' + model.replace(/^gpt-/, '')
  return model
}

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
const fmtShort = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })

// Stat breakdown text
const topModel = sortedModels[0]
const topPost = perPost[0]
const human = originals.length

const sections = [
  { id: 'premise',  label: 'Premise' },
  { id: 'glance',   label: 'At a glance' },
  { id: 'models',   label: 'Authors' },
  { id: 'posts',    label: 'Most edited posts' },
  { id: 'activity', label: 'Recent activity' },
  { id: 'rules',    label: 'The rules' },
  { id: 'method',   label: 'Methodology' },
]
---

<Base title="The experiment" description="A live record of how this blog is co-authored with AI agents. Models, revisions, captured session traces, and the human-only posts that the agents are forbidden from editing." wide>
  <div class="lab">
    <aside class="toc" aria-label="Sections">
      <div class="toc-eyebrow">The experiment</div>
      <ol>
        {sections.map((s) => (
          <li><a href={`#${s.id}`} data-toc={s.id}>{s.label}</a></li>
        ))}
      </ol>
      <div class="toc-stats">
        {aiPosts.length + originals.length} posts &nbsp; {totalRevisions} revs &nbsp; {distinctModels} models
      </div>
    </aside>

    <article class="lab-main">

      <section id="premise" class="block">
        <h2 class="block-h">Premise</h2>
        <p class="lede">
          This blog is a live experiment in human–AI co-authorship. Most posts here are drafted,
          edited, or revisited by AI agents under my direction. Every revision the system can
          observe is logged: the model that made it, when it landed, what changed, and (when
          captured) the full session trace that produced it.
        </p>
        <p class="lede-sub">
          Some posts are mine alone &mdash; hand-written, untouched by AI. The two are kept
          visually distinct. The rest of this page is the dashboard of the AI side.
        </p>
      </section>

      <section id="glance" class="block">
        <h2 class="block-h">At a glance</h2>
        <div class="glance-grid">
          <div class="card" data-card>
            <div class="card-v">{aiPosts.length}</div>
            <div class="card-l">AI-touched posts</div>
            <div class="card-tip">{originals.length} more written by hand</div>
          </div>
          <div class="card" data-card>
            <div class="card-v">{totalRevisions}</div>
            <div class="card-l">Tracked revisions</div>
            <div class="card-tip">{reconstructedCount} reconstructed from old commits</div>
          </div>
          <div class="card" data-card>
            <div class="card-v">{distinctModels}</div>
            <div class="card-l">Distinct models</div>
            {topModel && <div class="card-tip"><strong>{short(topModel[0])}</strong> leads with {topModel[1]}</div>}
          </div>
          <div class="card card-human" data-card>
            <div class="card-v">{human}</div>
            <div class="card-l">Human originals</div>
            <div class="card-tip">{humanRevisionCount} human edit{humanRevisionCount === 1 ? '' : 's'} on AI posts</div>
          </div>
        </div>
      </section>

      <section id="models" class="block">
        <h2 class="block-h">Authors</h2>
        <p class="block-sub">Every author who has touched a post — humans in green, models in violet/blue. Hover a row to see which posts they edited and when.</p>
        <ul class="models">
          {sortedModels.map(([m, n]) => {
            const cv = colorForModel[m]
            const titles = Array.from(modelPosts[m] ?? []).slice(0, 6)
            const more = (modelPosts[m]?.size ?? 0) - titles.length
            return (
              <li class="model-row" style={`--c: var(${cv});`}>
                <div class="model-summary">
                  <span class="model-dot" aria-hidden="true"></span>
                  <span class="model-name">{short(m)}</span>
                  <span class="model-bar"><span class="model-bar-fill" style={`width: ${(n / maxModel) * 100}%`}></span></span>
                  <span class="model-count">{n}</span>
                  <span class="model-last">last {fmtShort(modelLatest[m])}</span>
                </div>
                <div class="model-detail">
                  <div class="md-label">Posts touched ({modelPosts[m]?.size ?? 0})</div>
                  <ul class="md-titles">
                    {titles.map((t) => <li>{t}</li>)}
                    {more > 0 && <li class="md-more">+{more} more</li>}
                  </ul>
                </div>
              </li>
            )
          })}
        </ul>
      </section>

      <section id="posts" class="block">
        <h2 class="block-h">Most edited posts</h2>
        <p class="block-sub">Posts the loop keeps coming back to. Hover the row to see the revision timeline. Each dot is one edit, colored by model, plotted on the post's lifetime.</p>
        <ul class="posts">
          {perPost.slice(0, 12).map((p) => {
            const start = p.date
            const end = p.revs[p.revs.length - 1]?.date ?? p.date
            const lifeMs = Math.max(1, end.valueOf() - start.valueOf())
            return (
              <li class="post-row">
                <a href={`/posts/${p.id}`} class="post-link">
                  <span class="post-count">{p.revs.length}</span>
                  <span class="post-title">{p.title}</span>
                  <span class="post-span">{fmtShort(start)} <span class="post-arrow">→</span> {fmtShort(end)}</span>
                </a>
                <div class="post-timeline" aria-hidden="true">
                  <div class="post-track"></div>
                  {p.revs.map((r) => {
                    const pct = lifeMs > 0 ? ((r.date.valueOf() - start.valueOf()) / lifeMs) * 100 : 0
                    return (
                      <span
                        class="post-dot"
                        style={`left: ${pct}%; background: var(${colorForModel[r.model] ?? '--fg-faint'});`}
                        title={`${short(r.model)} · ${fmtDate(r.date)} · ${r.note}`}
                      ></span>
                    )
                  })}
                </div>
              </li>
            )
          })}
        </ul>
      </section>

      <section id="activity" class="block">
        <h2 class="block-h">Recent activity</h2>
        <p class="block-sub">The last {recent.length} edits the system observed. <a href="/traces" class="inline-link">Open the full trace log →</a></p>
        <ol class="timeline">
          {recent.map((r) => (
            <li class="t-row">
              <div class="t-bar" style={`background: var(${colorForModel[r.model] ?? '--fg-faint'});`}></div>
              <div class="t-body">
                <div class="t-meta">
                  <time class="t-date">{fmtDate(r.date)}</time>
                  <span class="t-model" style={`color: var(${colorForModel[r.model] ?? '--fg-faint'});`}>{short(r.model)}</span>
                  {r.reconstructed && <span class="t-recon">reconstructed</span>}
                </div>
                <div class="t-note">{r.note}</div>
                <div class="t-foot">
                  <a href={`/posts/${r.postId}`} class="t-post">{r.postTitle}</a>
                  {r.trace_id && <a href={`/traces/${r.trace_id}`} class="t-action">trace →</a>}
                  {r.commit && <span class="t-commit">{r.commit.slice(0, 7)}</span>}
                </div>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <section id="rules" class="block">
        <h2 class="block-h">The rules</h2>
        <div class="rules">
          <div class="rule rule-ai">
            <div class="rule-h">AI may edit</div>
            <ul>
              <li>Any post without <code>original: true</code> in its frontmatter</li>
              <li>Frontmatter (title, description, tags) when revising content</li>
              <li>Components in <code>src/components/</code> and layouts</li>
              <li>The trace-capture pipeline itself</li>
            </ul>
          </div>
          <div class="rule rule-human">
            <div class="rule-h">AI must not edit</div>
            <ul>
              <li>Any post with <code>original: true</code> &mdash; hard rule, in CLAUDE.md</li>
              <li>The list of authors on a human post</li>
              <li>Revision logs older than the agent's session start</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="method" class="block">
        <h2 class="block-h">Methodology</h2>
        <p class="block-sub">How the dashboard above is built.</p>
        <ol class="method">
          <li>
            <span class="m-n">1</span>
            <div>
              <div class="m-h">Capture</div>
              <p>A post-commit hook checks whether any <code>src/content/posts/*.mdx</code> file changed. If so, the script reads the active session log (Claude Code or Codex), extracts the model, timestamp, and a one-line change note, and appends a revision entry to the post's frontmatter with a <code>trace_id</code>.</p>
            </div>
          </li>
          <li>
            <span class="m-n">2</span>
            <div>
              <div class="m-h">Trace store</div>
              <p>Each captured session is written to <code>src/content/traces/&lt;trace_id&gt;.json</code> &mdash; the full message stream, tool calls, and artifacts. The traces collection is loaded by Astro's content layer at build time.</p>
            </div>
          </li>
          <li>
            <span class="m-n">3</span>
            <div>
              <div class="m-h">Reconstruction</div>
              <p>Posts written before the capture pipeline existed have a single <code>reconstructed: true</code> revision back-filled from the git history. Models for those entries are best-guess, marked clearly in the UI.</p>
            </div>
          </li>
          <li>
            <span class="m-n">4</span>
            <div>
              <div class="m-h">Aggregation</div>
              <p>This page reads every post's frontmatter at build time, joins it with the trace store, and renders the dashboard. There is no database. Everything you see here is in the repo.</p>
            </div>
          </li>
        </ol>
      </section>

    </article>
  </div>

  <script>
    // Highlight the current ToC item as the user scrolls.
    const items = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc]'))
    if (items.length && 'IntersectionObserver' in window) {
      const map = new Map(items.map((a) => [a.getAttribute('data-toc'), a]))
      const seen = new Set<string>()
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) seen.add(e.target.id)
            else seen.delete(e.target.id)
          }
          // Pick the topmost visible section
          const ids = Array.from(seen)
          const first = ids
            .map((id) => document.getElementById(id))
            .filter(Boolean)
            .sort((a, b) => a!.getBoundingClientRect().top - b!.getBoundingClientRect().top)[0]
          for (const a of items) a.classList.remove('is-active')
          if (first) map.get(first.id)?.classList.add('is-active')
        },
        { rootMargin: '-20% 0px -60% 0px', threshold: 0 },
      )
      for (const a of items) {
        const el = document.getElementById(a.getAttribute('data-toc')!)
        if (el) io.observe(el)
      }
    }
  </script>
</Base>

<style>
  .lab {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* Sticky ToC — quiet sidebar, no pills, no numbering, hairline accent on active.
     Override the global `aside { border-left, padding, margin }` rule that's
     intended for inline prose asides — this is a layout aside, not a callout. */
  .toc {
    position: sticky;
    top: var(--space-lg);
    align-self: start;
    padding: var(--space-md) 0;
    border-left: 0;
    margin: 0;
    color: inherit;
    font-size: inherit;
  }
  .toc-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--fg-faint);
    margin-bottom: 0.7rem;
  }
  .toc ol { list-style: none; padding: 0; margin: 0; }
  .toc li { margin: 0; }
  .toc a {
    display: block;
    padding: 0.18rem 0;
    font-family: var(--font-body);
    font-size: 14.5px;
    line-height: 1.45;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 0.1s;
  }
  .toc a:hover { color: var(--fg); }
  .toc a.is-active {
    color: var(--c-action);
    font-weight: 600;
  }
  .toc-stats {
    margin-top: 0.9rem;
    padding-top: 0.55rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--fg-faint);
    letter-spacing: 0.04em;
  }

  /* Main column */
  .lab-main { min-width: 0; }
  .block { margin: 0 0 var(--space-3xl); scroll-margin-top: var(--space-xl); }
  .block:first-child { margin-top: 0; }
  .block-h {
    font-family: var(--font-body);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-md);
  }
  .block-sub {
    font-size: 1rem;
    color: var(--fg-muted);
    margin: 0 0 var(--space-lg);
    max-width: 60ch;
  }
  .lede { font-size: 1.12rem; line-height: 1.65; margin: 0 0 var(--space-md); max-width: 65ch; }
  .lede-sub { font-size: 1rem; color: var(--fg-muted); line-height: 1.65; margin: 0; max-width: 65ch; }

  .inline-link { color: var(--c-action); text-decoration: none; border-bottom: 1px solid var(--c-action-border); }
  .inline-link:hover { background: var(--c-action-bg); }

  /* Glance cards — hover swaps label for tip */
  .glance-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.75rem;
  }
  .card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.1rem;
    background: var(--bg);
    transition: border-color 0.15s, transform 0.15s;
    cursor: default;
    overflow: hidden;
  }
  .card:hover { border-color: var(--c-action-border); transform: translateY(-1px); }
  .card-human:hover { border-color: var(--c-human-border, var(--border-strong)); }
  .card-v {
    font-family: var(--font-body);
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--c-action);
  }
  .card-human .card-v { color: var(--c-human, var(--fg)); }
  .card-l, .card-tip {
    font-family: var(--font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-top: 0.6rem;
    transition: opacity 0.15s, transform 0.15s;
  }
  .card-l { color: var(--fg-faint); }
  .card-tip {
    position: absolute;
    left: 1.1rem;
    right: 1.1rem;
    bottom: 1rem;
    color: var(--fg);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: 11.5px;
    opacity: 0;
    transform: translateY(4px);
  }
  .card-tip strong { color: var(--c-action); font-weight: 600; }
  .card:hover .card-l { opacity: 0; transform: translateY(-4px); }
  .card:hover .card-tip { opacity: 1; transform: translateY(0); }

  /* Models — hoverable rows with inline detail panel */
  .models { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--border); }
  .model-row { border-bottom: 1px solid var(--border); transition: background 0.15s; }
  .model-row:hover { background: var(--bg-alt); }
  .model-summary {
    display: grid;
    grid-template-columns: 14px 200px 1fr 3rem 7rem;
    align-items: center;
    gap: 0.9rem;
    padding: 0.7rem 0.6rem;
    cursor: default;
  }
  .model-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--c) 18%, transparent);
  }
  .model-name { font-family: var(--font-mono); font-size: 12.5px; font-weight: 600; color: var(--fg); }
  .model-bar { height: 6px; background: var(--bg-alt); border-radius: 3px; overflow: hidden; position: relative; }
  .model-row:hover .model-bar { background: var(--bg-sink); }
  .model-bar-fill { display: block; height: 100%; background: var(--c); border-radius: 3px; }
  .model-count {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-muted);
    font-variant-numeric: tabular-nums;
    text-align: right;
    font-weight: 600;
  }
  .model-last { font-family: var(--font-mono); font-size: 11px; color: var(--fg-faint); text-align: right; }
  .model-detail {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.22s ease;
    padding: 0 0.6rem;
  }
  .model-row:hover .model-detail { max-height: 240px; padding-bottom: 0.8rem; }
  .md-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
    margin-bottom: 0.4rem;
  }
  .md-titles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.6rem;
  }
  .md-titles li {
    font-size: 0.92rem;
    color: var(--fg-muted);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
  }
  .md-titles li.md-more { color: var(--fg-faint); border-style: dashed; }

  /* Posts — hover reveals timeline */
  .posts { list-style: none; padding: 0; margin: 0; }
  .post-row {
    border-bottom: 1px dotted var(--border);
    transition: background 0.15s;
  }
  .post-row:hover { background: var(--bg-alt); }
  .post-link {
    display: grid;
    grid-template-columns: 2.6rem 1fr auto;
    align-items: baseline;
    gap: 1rem;
    padding: 0.65rem 0.6rem 0.5rem;
    text-decoration: none;
    color: var(--fg);
  }
  .post-count {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    color: var(--c-action);
    font-variant-numeric: tabular-nums;
  }
  .post-title { font-family: var(--font-body); font-size: 1.08rem; }
  .post-row:hover .post-title { text-decoration: underline; text-decoration-color: var(--border-strong); }
  .post-span { font-family: var(--font-mono); font-size: 11px; color: var(--fg-faint); }
  .post-arrow { color: var(--fg-faint); }
  .post-timeline {
    position: relative;
    height: 0;
    margin: 0 0.6rem;
    overflow: hidden;
    transition: height 0.22s ease, margin 0.22s ease;
  }
  .post-row:hover .post-timeline { height: 24px; margin: 0 0.6rem 0.6rem; }
  .post-track {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border);
  }
  .post-dot {
    position: absolute;
    top: 50%;
    width: 8px; height: 8px;
    margin-left: -4px;
    margin-top: -4px;
    border-radius: 50%;
    border: 1.5px solid var(--bg);
    box-shadow: 0 0 0 1px currentColor;
  }

  /* Recent activity timeline */
  .timeline { list-style: none; padding: 0; margin: 0; }
  .t-row {
    display: grid;
