---
import Base from '../../layouts/Base.astro'
import DataTable, { type Col } from '../../components/DataTable.astro'
import Paginator from '../../components/Paginator.astro'
import { getCollection } from 'astro:content'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths: GetStaticPaths = async () => {
  const PER_PAGE = 10
  const posts = (await getCollection('posts', ({ data }) => !data.draft))
  let total = 0
  for (const p of posts) total += (p.data.revisions ?? []).length
  const totalPages = Math.max(1, Math.ceil(total / PER_PAGE))
  const out: any[] = []
  for (let p = 1; p <= totalPages; p++) {
    out.push({ params: { page: p === 1 ? undefined : String(p) }, props: { page: p, totalPages, total } })
  }
  return out
}

const PER_PAGE = 10
const { page: safePage, total } = Astro.props as { page: number; totalPages: number; total: number }

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

type Rev = {
  date: Date
  model: string
  note: string
  commit?: string
  reconstructed?: boolean
  trace_id?: string
  postId: string
  postTitle: string
}

const allRevisions: Rev[] = []
const modelCounts: Record<string, number> = {}

for (const post of posts) {
  for (const r of post.data.revisions ?? []) {
    allRevisions.push({ ...r, postId: post.id, postTitle: post.data.title })
    modelCounts[r.model] = (modelCounts[r.model] ?? 0) + 1
  }
}

allRevisions.sort((a, b) => b.date.valueOf() - a.date.valueOf())

const postRevCounts = posts
  .map((p) => ({
    id: p.id,
    title: p.data.title,
    n: (p.data.revisions ?? []).length,
  }))
  .filter((x) => x.n > 0)
  .sort((a, b) => b.n - a.n)

const totalRevisions = allRevisions.length
const reconstructedCount = allRevisions.filter((r) => r.reconstructed).length

const short = (model: string): string => {
  if (!model || model === 'unknown') return 'unknown'
  if (model.startsWith('claude-')) {
    const parts = model.replace(/^claude-/, '').split('-')
    if (parts.length >= 2) return parts[0][0].toUpperCase() + parts[0].slice(1) + ' ' + parts.slice(1).join('.')
  }
  if (model.startsWith('gpt-')) return 'GPT-' + model.replace(/^gpt-/, '')
  return model
}

const sortedModels = Object.entries(modelCounts).sort((a, b) => b[1] - a[1])
const maxModel = sortedModels[0]?.[1] ?? 1

// Table rows
const allRows = allRevisions.map((r) => ({
  date: r.date.toISOString(),
  post: r.postTitle,
  postHref: `/posts/${r.postId}`,
  model: short(r.model),
  note: r.note,
  trace: r.trace_id ? 'open →' : '',
  traceHref: r.trace_id ? `/traces/${r.trace_id}` : undefined,
  commit: r.commit ? r.commit.slice(0, 7) : '',
  reconstructed: r.reconstructed,
}))

const rows = allRows.slice((safePage - 1) * PER_PAGE, safePage * PER_PAGE)

const columns: Col[] = [
  { key: 'date',    label: 'Date',   type: 'date', width: '7rem' },
  { key: 'post',    label: 'Post',   type: 'link', linkKey: 'postHref' },
  { key: 'model',   label: 'Model',  type: 'mono', width: '8rem', tone: (v) => v === 'unknown' ? 'neutral' : 'action' as any },
  { key: 'note',    label: 'Change note' },
  { key: 'trace',   label: 'Trace',  type: 'link', linkKey: 'traceHref', width: '5rem' },
  { key: 'commit',  label: 'Commit', type: 'mono', width: '5rem' },
]
---

<Base title="experiment" wide>
  <section class="intro">
    <h1>The experiment</h1>
    <p>
      Every post on this blog was drafted, edited, or revisited by AI agents &mdash; Claude Opus,
      Claude Sonnet, and occasionally GPT-5.x &mdash; under my direction. Model versions change.
      Posts get revisited. Diagrams that a newer model sees something in get redrawn. This page
      is the record.
    </p>
    <p class="intro-sub">
      Comments, reactions, and revisions are fed back into a content eval that decides what to
      write next. Older posts where the exact trace is lost are marked <em>reconstructed</em>;
      the authored record here is approximate for pre-2026-04 work.
    </p>
  </section>

  <section class="stats">
    <div class="stat-card"><div class="sv">{posts.length}</div><div class="sl">Posts</div></div>
    <div class="stat-card"><div class="sv">{totalRevisions}</div><div class="sl">Tracked revisions</div></div>
    <div class="stat-card"><div class="sv">{Object.keys(modelCounts).length}</div><div class="sl">Distinct models</div></div>
    <div class="stat-card"><div class="sv">{reconstructedCount}</div><div class="sl">Reconstructed entries</div></div>
  </section>

  {sortedModels.length > 0 && (
    <section class="section">
      <h2>Model distribution</h2>
      <p class="section-sub">Revisions per model. The model that did the most editing sits at the top.</p>
      <div class="model-bars">
        {sortedModels.map(([m, n]) => (
          <div class="mb-row">
            <span class="mb-label">{short(m)}</span>
            <div class="mb-track"><div class="mb-fill" style={`width: ${(n / maxModel) * 100}%`}></div></div>
            <span class="mb-count">{n}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <h2>Most-revisited posts</h2>
    <p class="section-sub">Posts that got rewritten, polished, or redrawn the most. These are the ones the loop keeps coming back to.</p>
    <DataTable
      columns={[
        { key: 'title', label: 'Post', type: 'link', linkKey: 'href' },
        { key: 'n', label: 'Revisions', type: 'num', align: 'right', width: '8rem' },
      ]}
      rows={postRevCounts.map((p) => ({ title: p.title, href: `/posts/${p.id}`, n: p.n }))}
      initialSort={{ key: 'n', dir: 'desc' }}
    />
  </section>

  <section class="section">
    <h2>All revisions</h2>
    <p class="section-sub">Every edit, the model that made it, and the post it landed on. Click a trace to read the captured session.</p>
    <DataTable
      columns={columns}
      rows={rows}
      initialSort={{ key: 'date', dir: 'desc' }}
    />
    <Paginator page={safePage} total={total} perPage={PER_PAGE} basePath="/experiment" />
  </section>
</Base>

<style>
  .intro { margin: var(--space-xl) 0 var(--space-2xl); max-width: 780px; }
  .intro h1 { font-size: 2.4rem; letter-spacing: -0.02em; margin: 0 0 var(--space-md); }
  .intro p { font-size: 1.08rem; line-height: 1.6; margin: 0 0 var(--space-md); }
  .intro-sub { color: var(--fg-muted); font-size: 0.98rem !important; }

  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 0.75rem;
    margin: 0 0 var(--space-2xl);
  }
  .stat-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.9rem 1.1rem;
    background: var(--bg);
  }
  .sv {
    font-family: var(--font-body);
    font-size: 2.1rem;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--c-action);
  }
  .sl {
    font-family: var(--font-mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
    margin-top: 0.35rem;
  }

  .section { margin: 0 0 var(--space-2xl); }
  .section h2 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0 0 0.3rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px dotted var(--border);
  }
  .section-sub {
    font-size: 0.95rem;
    color: var(--fg-muted);
    margin: 0 0 var(--space-lg);
    max-width: 640px;
  }

  .model-bars { display: flex; flex-direction: column; gap: 0.5rem; }
  .mb-row {
    display: grid;
    grid-template-columns: 180px 1fr 3rem;
    align-items: center;
    gap: 0.8rem;
  }
  .mb-label { font-family: var(--font-mono); font-size: 12px; font-weight: 600; color: var(--fg); }
  .mb-track { height: 10px; background: var(--bg-alt); border-radius: 5px; overflow: hidden; }
  .mb-fill { height: 100%; background: var(--c-action); border-radius: 5px; }
  .mb-count {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--fg-muted);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }
</style>
