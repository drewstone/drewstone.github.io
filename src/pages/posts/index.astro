---
import Base from '../../layouts/Base.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const grouped = posts.reduce<Record<number, typeof posts>>((acc, post) => {
  const year = post.data.date.getFullYear()
  ;(acc[year] ??= []).push(post)
  return acc
}, {})

const years = Object.keys(grouped).map(Number).sort((a, b) => b - a)
---

<Base title="archive" wide>
  <section class="archive-header">
    <h1>Archive</h1>
    <p class="count">{posts.length} posts</p>
  </section>

  <hr class="rule" />

  {years.map((year) => (
    <section class="year-section">
      <h2 class="year-label">{year}</h2>
      <ul class="archive-list">
        {grouped[year].map((post) => (
          <li>
            <time>{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</time>
            <a href={`/posts/${post.id}`}>{post.data.title}</a>
            <span class="desc">{post.data.description}</span>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>

<style>
  .archive-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
    padding-bottom: var(--space-md);
  }

  .archive-header h1 {
    margin: 0;
    font-size: 1.6rem;
  }

  .count {
    font-size: 0.82rem;
    color: var(--fg-faint);
    margin: 0;
  }

  .year-section {
    padding: var(--space-lg) 0;
  }

  .year-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--fg-faint);
    letter-spacing: 0.05em;
    margin: 0 0 var(--space-sm);
    border: none;
    padding: 0;
  }

  .archive-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .archive-list li {
    display: grid;
    grid-template-columns: 5rem 1fr;
    grid-template-rows: auto auto;
    gap: 0 var(--space-lg);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--border);
    align-items: baseline;
  }

  .archive-list li:last-child {
    border-bottom: none;
  }

  .archive-list time {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-faint);
    grid-row: 1;
  }

  .archive-list a {
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    color: var(--fg);
    grid-row: 1;
    grid-column: 2;
  }

  .archive-list a:hover {
    text-decoration: underline;
  }

  .desc {
    font-size: 0.82rem;
    color: var(--fg-muted);
    grid-row: 2;
    grid-column: 2;
    margin-top: 2px;
  }

  @media (max-width: 640px) {
    .archive-list li {
      grid-template-columns: 1fr;
    }

    .archive-list time {
      grid-row: auto;
      grid-column: auto;
    }

    .archive-list a {
      grid-row: auto;
      grid-column: auto;
    }

    .desc {
      grid-row: auto;
      grid-column: auto;
    }
  }
</style>
