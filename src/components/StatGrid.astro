---
/**
 * StatGrid — horizontal strip of Stat components, equal-width.
 * Wrap 2–4 <Stat /> children inside.
 */
---
<div class="stat-grid"><slot /></div>

<style>
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.75rem;
    margin: var(--space-xl) 0;
  }

  @media (min-width: 800px) {
    .stat-grid {
      margin-left: -1rem;
      margin-right: -1rem;
    }
  }
</style>
