---
interface Props {
  id: string
  width?: number
  height?: number
}

const { id, width = 640, height = 400 } = Astro.props
---

<figure class="animation-container">
  <canvas id={id} width={width} height={height}></canvas>
</figure>

<script define:vars={{ id, width, height }}>
  const canvas = document.getElementById(id)
  if (canvas) {
    const ctx = canvas.getContext('2d')
    const particles = Array.from({ length: 60 }, (_, i) => ({
      angle: (i / 60) * Math.PI * 2,
      radius: 80 + Math.random() * 100,
      speed: 0.003 + Math.random() * 0.008,
      size: 1.5 + Math.random() * 2.5,
      offset: Math.random() * Math.PI * 2,
      wobble: 0.5 + Math.random() * 2,
    }))

    const style = getComputedStyle(document.documentElement)
    const fg = style.getPropertyValue('--fg').trim() || '#e7e5e4'
    const accent = style.getPropertyValue('--accent').trim() || '#f59e0b'
    const bg = style.getPropertyValue('--bg').trim() || '#0c0a09'

    let frame = 0
    let animId = null

    function draw() {
      ctx.fillStyle = bg
      ctx.fillRect(0, 0, width, height)

      const cx = width / 2
      const cy = height / 2

      for (const p of particles) {
        p.angle += p.speed
        const wobbleR = p.radius + Math.sin(frame * 0.02 + p.offset) * p.wobble * 8
        const x = cx + Math.cos(p.angle) * wobbleR
        const y = cy + Math.sin(p.angle) * wobbleR * 0.6

        const alpha = 0.3 + 0.7 * ((wobbleR - 60) / 140)
        ctx.beginPath()
        ctx.arc(x, y, p.size, 0, Math.PI * 2)
        ctx.fillStyle = p.size > 3 ? accent : fg
        ctx.globalAlpha = alpha
        ctx.fill()
      }

      ctx.globalAlpha = 1
      frame++
      animId = requestAnimationFrame(draw)
    }

    // pause when off-screen
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          if (!animId) draw()
        } else if (animId) {
          cancelAnimationFrame(animId)
          animId = null
        }
      },
      { threshold: 0.1 }
    )
    observer.observe(canvas)
  }
</script>

<style>
  .animation-container {
    margin: var(--space-lg) 0;
    text-align: center;
  }

  .animation-container canvas {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    border: 1px solid var(--border);
  }
</style>
