---
/**
 * Paginator — prev/next + page numbers via ?page=N query param.
 *
 * Usage:
 *   <Paginator page={page} total={total} perPage={25} basePath="/traces" />
 *
 * The calling page is responsible for slicing its rows based on `page` * perPage.
 */
interface Props {
  page: number
  total: number
  perPage: number
  basePath: string
}

const { page, total, perPage, basePath } = Astro.props
const totalPages = Math.max(1, Math.ceil(total / perPage))
const safePage = Math.max(1, Math.min(totalPages, page))

const href = (p: number) => (p === 1 ? basePath : `${basePath}?page=${p}`)

// Compute a compact page-number window: first, last, and a few around current
function pageWindow(cur: number, total: number): (number | '…')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1)
  const set = new Set<number>([1, total, cur - 1, cur, cur + 1])
  const pages = [...set].filter((p) => p >= 1 && p <= total).sort((a, b) => a - b)
  const out: (number | '…')[] = []
  for (let i = 0; i < pages.length; i++) {
    if (i > 0 && pages[i] - pages[i - 1] > 1) out.push('…')
    out.push(pages[i])
  }
  return out
}

const pages = pageWindow(safePage, totalPages)
const showFrom = (safePage - 1) * perPage + 1
const showTo = Math.min(total, safePage * perPage)
---

{total > perPage && (
  <nav class="paginator" aria-label="pagination">
    <div class="pg-range">
      {showFrom}&ndash;{showTo} <span class="pg-of">of</span> {total}
    </div>
    <div class="pg-controls">
      <a
        class={`pg-btn pg-prev ${safePage === 1 ? 'disabled' : ''}`}
        href={safePage === 1 ? undefined : href(safePage - 1)}
        aria-disabled={safePage === 1}
      >
        &larr; Prev
      </a>
      <div class="pg-pages">
        {pages.map((p) =>
          p === '…' ? (
            <span class="pg-ellipsis">&hellip;</span>
          ) : (
            <a class={`pg-num ${p === safePage ? 'is-current' : ''}`} href={href(p)} aria-current={p === safePage ? 'page' : undefined}>
              {p}
            </a>
          )
        )}
      </div>
      <a
        class={`pg-btn pg-next ${safePage === totalPages ? 'disabled' : ''}`}
        href={safePage === totalPages ? undefined : href(safePage + 1)}
        aria-disabled={safePage === totalPages}
      >
        Next &rarr;
      </a>
    </div>
  </nav>
)}

<style>
  .paginator {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin: var(--space-xl) 0 0;
    padding-top: var(--space-md);
    border-top: 1px dotted var(--border);
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--fg-muted);
    flex-wrap: wrap;
  }

  .pg-range {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }
  .pg-of {
    color: var(--fg-faint);
    margin: 0 0.25em;
  }

  .pg-controls {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .pg-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.32rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    color: var(--fg);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    transition: background 0.12s, border-color 0.12s;
  }
  .pg-btn:hover:not(.disabled) {
    background: var(--bg-alt);
    border-color: var(--border-strong);
  }
  .pg-btn.disabled {
    opacity: 0.4;
    pointer-events: none;
  }

  .pg-pages {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0 0.3rem;
  }

  .pg-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    height: 1.75rem;
    padding: 0 0.4rem;
    border-radius: 4px;
    color: var(--fg-muted);
    text-decoration: none;
    font-variant-numeric: tabular-nums;
    font-size: 11.5px;
  }
  .pg-num:hover { background: var(--bg-alt); color: var(--fg); }
  .pg-num.is-current {
    background: var(--c-action);
    color: var(--bg);
    font-weight: 700;
  }
  .pg-num.is-current:hover { background: var(--c-action); color: var(--bg); }

  .pg-ellipsis { color: var(--fg-faint); padding: 0 0.15rem; }

  @media (max-width: 600px) {
    .paginator { flex-direction: column; align-items: stretch; }
    .pg-controls { justify-content: space-between; }
  }
</style>
