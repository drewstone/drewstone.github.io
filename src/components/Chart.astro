---
interface Props {
  id: string
  code: string
}

const { id, code } = Astro.props
---

<figure class="chart-container" id={id}>
  <div class="chart-inner"></div>
</figure>

<script define:vars={{ id, code }}>
  requestAnimationFrame(() => {
    const container = document.querySelector(`#${id} .chart-inner`)
    if (!container) return
    try {
      const _cw = container.clientWidth
      if (_cw === 0) return
      const _dimMatch = code.match(/const W\s*=\s*(\d+),\s*H\s*=\s*(\d+)/)
      const _origW = _dimMatch ? parseInt(_dimMatch[1]) : 0
      const _origH = _dimMatch ? parseInt(_dimMatch[2]) : 0
      const _newH = _origW > 0 ? Math.round(_origH * (_cw / _origW)) : 0

      const wrappedCode = `
        const _origCreate = document.createElement.bind(document)
        const _dpr = window.devicePixelRatio || 1
        const _cw = ${_cw}
        const _newH = ${_newH}
        const _origW = ${_origW}
        document.createElement = function(tag, opts) {
          const el = _origCreate(tag, opts)
          if (tag === 'canvas') {
            const _origGetCtx = el.getContext.bind(el)
            let _scaled = false
            el.getContext = function(type, attrs) {
              const ctx = _origGetCtx(type, attrs)
              if (type === '2d' && !_scaled) {
                _scaled = true
                const _dw = el.width, _dh = el.height
                if (_origW > 0 && _cw !== _dw) {
                  el.width = _cw * _dpr
                  el.height = _newH * _dpr
                  el.style.width = _cw + 'px'
                  el.style.height = _newH + 'px'
                  ctx.scale(_dpr * _cw / _dw, _dpr * _newH / _dh)
                } else if (_dpr > 1) {
                  el.width = _dw * _dpr
                  el.height = _dh * _dpr
                  el.style.width = _dw + 'px'
                  el.style.height = _dh + 'px'
                  ctx.scale(_dpr, _dpr)
                }
              }
              return ctx
            }
          }
          return el
        }
        ${code}
        document.createElement = _origCreate
      `
      const fn = new Function('container', wrappedCode)
      fn(container)
    } catch (e) {
      container.textContent = `Chart error: ${e.message}`
    }
  })
</script>

<style>
  .chart-container {
    margin: var(--space-xl) calc(-1 * var(--space-lg));
  }

  .chart-inner {
    display: block;
  }

  .chart-inner canvas {
    display: block;
    max-width: 100%;
  }

  @media (min-width: 800px) {
    .chart-container {
      margin-left: -5rem;
      margin-right: -5rem;
    }
  }
</style>
