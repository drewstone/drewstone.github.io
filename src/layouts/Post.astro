---
import Base from './Base.astro'
import AuthorBadges from '../components/AuthorBadges.astro'
import Revisions from '../components/Revisions.astro'
import PostReactions from '../components/PostReactions.astro'
import ParagraphReactor from '../components/ParagraphReactor.astro'
import RevisionMosaicToggle from '../components/RevisionMosaicToggle.astro'
import Giscus from '../components/Giscus.astro'

interface Author {
  model: string
  role: 'draft' | 'rewrite' | 'polish' | 'diagram' | 'review'
  date: Date
}
interface Revision {
  date: Date
  model: string
  note: string
  commit?: string
  reconstructed?: boolean
}

interface Props {
  title: string
  description: string
  date: Date
  updated?: Date
  tags?: string[]
  slug?: string
  authors?: Author[]
  revisions?: Revision[]
  original?: boolean
}

const { title, description, date, updated, tags = [], slug, authors, revisions, original = false } = Astro.props

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

const repo = import.meta.env.PUBLIC_REPO_SLUG as string | undefined

const site = Astro.site ?? new URL('https://drewstone.github.io')
const url = slug ? new URL(`/posts/${slug}`, site).toString() : new URL(Astro.url.pathname, site).toString()

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  author: { '@type': 'Person', name: 'Drew Stone', url: site.toString() },
  publisher: { '@type': 'Person', name: 'Drew Stone', url: site.toString() },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  url,
  keywords: tags.length ? tags.join(', ') : undefined,
  inLanguage: 'en',
}
---

<Base
  title={title}
  description={description}
  type="article"
  publishedTime={date}
  modifiedTime={updated}
  tags={tags}
  jsonLd={articleJsonLd}
>
  <article>
    <header class="post-header">
      <div class="post-meta-line">
        <time>{formatDate(date)}</time>
        {tags.length > 0 && (
          <span class="post-tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
          </span>
        )}
        {updated && <span class="updated">updated {formatDate(updated)}</span>}
      </div>
      <h1>{title}</h1>
      <p class="post-desc">{description}</p>
      <AuthorBadges authors={authors} original={original} />
      {!original && revisions && revisions.length > 0 && (
        <RevisionMosaicToggle
          lastDate={revisions[revisions.length - 1].date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          lastModel={revisions[revisions.length - 1].model}
        />
      )}
    </header>
    <div class={`prose${original ? ' prose-original' : ''}`}>
      <slot />
    </div>
    {!original && <Revisions revisions={revisions} repo={repo} />}
    {slug && <PostReactions slug={slug} />}
    {slug && <ParagraphReactor slug={slug} />}
    {slug && <Giscus term={slug} />}
  </article>
</Base>

<style>
  article {
    padding-top: var(--space-md);
  }

  .post-header {
    margin-bottom: var(--space-2xl);
  }

  .post-meta-line {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-md);
  }

  .post-tags {
    display: inline-flex;
    gap: var(--space-sm);
  }

  .post-header h1 {
    font-size: 2.6rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0 0 var(--space-md);
  }

  .post-desc {
    font-size: 1.1rem;
    color: var(--fg-muted);
    font-style: italic;
    margin: 0 0 var(--space-lg);
    line-height: 1.55;
    max-width: 640px;
  }

  .updated {
    color: var(--fg-faint);
  }

  .prose {
    line-height: 1.75;
    position: relative;
  }

  /* Subtle indicator on original posts: a thin colored hairline before
     the prose so it reads as a different document type. */
  .prose-original {
    position: relative;
  }
  .prose-original::before {
    content: '';
    position: absolute;
    left: -0.6rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--c-human);
    border-radius: 1px;
    opacity: 0.5;
  }

  .prose :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 640px) {
    .post-header h1 {
      font-size: 1.85rem;
    }
    .post-header {
      padding-top: 0;
    }
  }
</style>
