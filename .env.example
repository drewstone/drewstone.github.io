# Blog deploy-time configuration.
# Copy to `.env` locally; in production add to GitHub Pages repo secrets
# (or a `.env.production` committed build-time config if the site is public).

# Public URL origin of the deployed site (used by sitemap + RSS).
# Set in astro.config.mjs under `site:` — not in .env.
# e.g. https://drewstone.github.io/blog

# --- Repo for commit/trace links ---
# <owner>/<repo>. Used by <Revisions> and /traces/<id> to link commit SHAs.
PUBLIC_REPO_SLUG=

# --- Giscus (per-post comments via GitHub Discussions) ---
# Generate these at https://giscus.app after enabling Discussions on the repo.
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# --- Reactions (Cloudflare Worker + D1 + Turnstile) ---
# Worker URL returned by `wrangler deploy`, e.g.
#   https://blog-reactions.<subdomain>.workers.dev
PUBLIC_REACTIONS_API=

# Turnstile SITE key (client-side). Get from the Cloudflare Turnstile dashboard.
# The matching SECRET goes into the worker via `wrangler secret put TURNSTILE_SECRET`.
PUBLIC_TURNSTILE_SITE_KEY=
